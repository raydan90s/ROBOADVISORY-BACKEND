ails.py", "source_location": "L1"}, {"id": "d_github_roboadvisory_backend_tests_test_guardrails_rationale_44", "label": "El piso: un texto fiel a la base pasa. Si esto fallara, el guardarra\u00edl ser\u00eda in\u00fa", "file_type": "rationale", "source_file": "tests/test_guardrails.py", "source_location": "L44"}, {"id": "d_github_roboadvisory_backend_tests_test_guardrails_rationale_69", "label": "La alucinaci\u00f3n m\u00e1s peligrosa: el modelo \"suma\" y le da otra cifra al cliente.", "file_type": "rationale", "source_file": "tests/test_guardrails.py", "source_location": "L69"}, {"id": "d_github_roboadvisory_backend_tests_test_guardrails_rationale_77", "label": "12.000' es doce mil, no doce: si se leyeran igual, un monto falso pasar\u00eda colado", "file_type": "rationale", "source_file": "tests/test_guardrails.py", "source_location": "L77"}, {"id": "d_github_roboadvisory_backend_tests_test_guardrails_rationale_106", "label": "En letras, una cifra no se puede comparar contra la base: se rechaza entera.", "file_type": "rationale", "source_file": "tests/test_guardrails.py", "source_location": "L106"}, {"id": "d_github_roboadvisory_backend_tests_test_guardrails_rationale_111", "label": "\u00ablas dos opciones\u00bb es conversaci\u00f3n, no un dato: el prompt lo pide as\u00ed a prop\u00f3sit", "file_type": "rationale", "source_file": "tests/test_guardrails.py", "source_location": "L111"}, {"id": "d_github_roboadvisory_backend_tests_test_guardrails_rationale_118", "label": "El cierre no puede romper el piso: el texto fiel a la base sigue siendo v\u00e1lido.", "file_type": "rationale", "source_file": "tests/test_guardrails.py", "source_location": "L118"}, {"id": "d_github_roboadvisory_backend_tests_test_guardrails_rationale_141", "label": "El validador proh\u00edbe prometer, no proh\u00edbe la palabra 'riesgo'.", "file_type": "rationale", "source_file": "tests/test_guardrails.py", "source_location": "L141"}, {"id": "d_github_roboadvisory_backend_tests_test_guardrails_rationale_153", "label": "Un emisor inventado es tan grave como un porcentaje inventado.", "file_type": "rationale", "source_file": "tests/test_guardrails.py", "source_location": "L153"}, {"id": "d_github_roboadvisory_backend_tests_test_guardrails_rationale_168", "label": "Banco Pichincha existe y es AAA; decir que es AA+ es inventar el dato.", "file_type": "rationale", "source_file": "tests/test_guardrails.py", "source_location": "L168"}, {"id": "d_github_roboadvisory_backend_tests_test_guardrails_rationale_176", "label": "Lo que hace peligrosa a una alucinaci\u00f3n es venir envuelta en datos correctos.", "file_type": "rationale", "source_file": "tests/test_guardrails.py", "source_location": "L176"}], "edges": [{"source": "d_github_roboadvisory_backend_tests_test_guardrails_py", "target": "decimal", "relation": "imports_from", "context": "import", "confidence": "EXTRACTED", "source_file": "tests/test_guardrails.py", "source_location": "L10", "weight": 1.0}, {"source": "d_github_roboadvisory_backend_tests_test_guardrails_py", "target": "pytest", "relation": "imports", "context": "import", "confidence": "EXTRACTED", "source_file": "tests/test_guardrails.py", "source_location": "L12", "weight": 1.0}, {"source": "d_github_roboadvisory_backend_tests_test_guardrails_py", "target": "src_services_guardrails", "relation": "imports_from", "context": "import", "confidence": "EXTRACTED", "source_file": "tests/test_guardrails.py", "source_location": "L14", "weight": 1.0}, {"source": "d_github_roboadvisory_backend_tests_test_guardrails_py", "target": "d_github_roboadvisory_backend_tests_test_guardrails_test_texto_solo_con_datos_reales_es_aceptado", "relation": "contains", "confidence": "EXTRACTED", "source_file": "tests/test_guardrails.py", "source_location": "L43", "weight": 1.0}, {"source": "d_github_roboadvisory_backend_tests_test_guardrails_py", "target": "d_github_roboadvisory_backend_tests_test_guardrails_test_numero_inventado_es_rechazado", "relation": "contains", "confide