# Postgres de Supabase (Session pooler :5432 / Transaction pooler :6543)
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Firma de los JWT. Genera uno con:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# --- IA: proveedor intercambiable (ver src/services/llm_provider.py) ---
# Cambia SOLO esta variable para usar otro modelo: google | openai | anthropic.
AI_PROVIDER=google
AI_TEMPERATURE=0.2

# Google Gemini (default). Ojo: gemini-flash-latest resuelve a gemini-3.5-flash
# (free tier 20 req/día); gemini-flash-lite-latest tiene cuota aparte.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest

# OpenAI (opcional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (opcional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Mercados externos: ticker del dashboard + Rutas B/C del agente ---
# Sin key, el wrapper sirve cotizaciones simuladas (nunca se rompe el ticker/chat).
ALPHA_VANTAGE_API_KEY=

# --- WhatsApp (Twilio) ---
# El webhook es público (Twilio no manda JWT): la firma X-Twilio-Signature es lo que
# lo autentica. TWILIO_WEBHOOK_URL debe coincidir carácter por carácter con la URL
# configurada en la consola de Twilio, o toda firma se rechaza.
TWILIO_AUTH_TOKEN=
TWILIO_WEBHOOK_URL=
# false SOLO para probar el webhook con curl/ngrok en local.
TWILIO_VALIDAR_FIRMA=true
# El bot corre siempre sobre el proveedor con cuota, sin depender del selector del front.
WHATSAPP_AI_PROVIDER=openai

# --- Correo (SMTP de Gmail): verificación del registro y reseteo de contraseña ---
# SMTP_PASSWORD es una "Contraseña de aplicación" de 16 caracteres, NO la contraseña de
# la cuenta (Google la rechaza con 535). Requiere 2FA activo:
#   https://myaccount.google.com/apppasswords
# Vacío + APP_ENV=development → el código no se envía, se imprime en el log.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Brokeate
SMTP_FROM_EMAIL=
EMAIL_CODE_TTL_MINUTES=15

APP_ENV=development
CORS_ORIGINS=*
