# Postgres de Supabase (Session pooler :5432 / Transaction pooler :6543)
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Firma de los JWT. Genera uno con:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# --- IA: proveedor intercambiable (ver src/services/llm_provider.py) ---
# Cambia SOLO esta variable para usar otro modelo: google | openai | anthropic.
AI_PROVIDER=google
AI_TEMPERATURE=0.2

# Google Gemini (default). Ojo: gemini-flash-latest resuelve a gemini-3.5-flash
# (free tier 20 req/día); gemini-flash-lite-latest tiene cuota aparte.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest

# OpenAI (opcional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (opcional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Mercados externos: ticker del dashboard + Rutas B/C del agente ---
# Sin key, el wrapper sirve cotizaciones simuladas (nunca se rompe el ticker/chat).
ALPHA_VANTAGE_API_KEY=

APP_ENV=development
CORS_ORIGINS=*
